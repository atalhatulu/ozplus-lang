{
    "comments": {
        "lineComment": "//"
    },
    "brackets": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"]
    ],
    "autoClosingPairs": [
        {"open": "[", "close": "]"},
        {"open": "(", "close": ")"},
        {"open": "\"", "close": "\""}
    ],
    "surroundingPairs": [
        {"open": "[", "close": "]"},
        {"open": "(", "close": ")"},
        {"open": "\"", "close": "\""}
    ],
    "folding": {
        "markers": {
            "start": "^\\s*(islev|sinif|dongu|ise|degilse|dene|hata_yakala)\\b",
            "end": "^\\s*son\\b"
        }
    }
}
